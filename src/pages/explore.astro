---
export const prerender = true;
import Base from '../layouts/Base.astro';
import { getAnimeFavorites } from '../lib/content';
import { getFeaturedProjects } from '../lib/projects';

let featuredAnime: any[] = [];
let animeAvailable = true;

try {
  featuredAnime = (await getAnimeFavorites()).slice(0, 4);
} catch {
  animeAvailable = false;
}

const featuredProjects = await getFeaturedProjects();
---
<Base title="explore" description="Anime notes and discovery in one calm surface.">
  <header class="explore-header">
    <h1>explore</h1>
  </header>

  {animeAvailable && (
    <section class="group">
      <div class="group-head">
        <h2>fav animes</h2>
        <div class="group-links">
          <a href="/anime">all anime</a>
          <a href="/anime/notes">notes</a>
        </div>
      </div>
      <ul class="stream">
        {featuredAnime.map((entry) => (
          <li>
            <a href={`https://anishows.com/anime/${entry.anime.slug}`} class="row">
              <span>{entry.anime.title}</span>
              <span>{entry.anime.rating ? `${entry.anime.rating}/10` : '—'}</span>
            </a>
          </li>
        ))}
      </ul>
      {featuredAnime.length === 0 && <p class="empty">No anime entries yet.</p>}
    </section>
  )}

  <section class="group">
    <div class="group-head">
      <h2>projects</h2>
      <div class="group-links">
        <a href="/projects">all projects</a>
      </div>
    </div>
    <ul class="stream">
      {featuredProjects.map((project) => (
        <li>
          <a href={project.url || project.repo || '/projects'} class="row">
            <span>{project.title}</span>
            <span>{project.description}</span>
          </a>
        </li>
      ))}
    </ul>
    {featuredProjects.length === 0 && <p class="empty">No projects yet.</p>}
  </section>

  <section class="group">
    <div class="group-head">
      <h2>more</h2>
    </div>
    <ul class="stream">
      <li><a href="/projects" class="row"><span>projects</span><span>things i've built</span></a></li>
      <li><a href="/games" class="row"><span>games</span><span>interactive experiments</span></a></li>
      <li><a href="/about" class="row"><span>about</span><span>the human behind the site</span></a></li>
    </ul>
  </section>
</Base>

<style>
  .explore-header p {
    color: var(--color-ink-muted);
    max-width: 42ch;
  }

  .group {
    border-top: 1px solid var(--color-rule);
    padding-top: var(--space-sm);
    margin-top: var(--space-md);
  }

  .group-head h2 {
    margin: 0 0 0.5rem 0;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-ink-faint);
    text-transform: lowercase;
    letter-spacing: 0.04em;
  }

  .group-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }

  .group-links {
    display: flex;
    gap: 0.8rem;
  }

  .group-head a {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: lowercase;
  }

  .stream {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .stream li {
    border-bottom: 1px solid var(--color-rule);
  }

  .stream li:last-child {
    border-bottom: none;
  }

  .row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    padding: 0.65rem 0;
    color: var(--color-ink);
  }

  .row span:last-child {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-ink-faint);
    text-transform: lowercase;
  }

  .row-main {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .badge {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.1rem 0.4rem;
    border: 1px solid var(--color-rule);
    border-radius: 3px;
    color: var(--color-ink-faint);
    opacity: 0.8;
  }

  .badge.anime {
    color: #5e78b6;
  }


  .empty {
    margin: 0.4rem 0 0 0;
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
  }

  @media (max-width: 640px) {
    .row {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.18rem;
    }
  }
</style>
