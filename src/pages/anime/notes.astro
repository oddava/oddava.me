---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import { getAllAnime } from '../../lib/content';

const entries: any[] = await getAllAnime();
const statuses = Array.from(new Set(entries.map((entry) => entry.data.status)));
const years = Array.from(
  new Set(entries.map((entry) => entry.data.year).filter((year: number | undefined) => year)),
).sort((a: number, b: number) => b - a);
---
<Base title="anime notes" description="Notes and watch status for anime entries.">
  <header class="post-header">
    <h1>anime notes</h1>
    <p class="post-header__meta">filters for quick browsing</p>
  </header>

  <section class="notes-controls">
    <label>
      <span>search</span>
      <input type="search" placeholder="title" data-filter="search" />
    </label>
    <label>
      <span>status</span>
      <select data-filter="status">
        <option value="">all</option>
        {statuses.map((status) => (
          <option value={status}>{status}</option>
        ))}
      </select>
    </label>
    <label>
      <span>year</span>
      <select data-filter="year">
        <option value="">all</option>
        {years.map((year) => (
          <option value={year}>{year}</option>
        ))}
      </select>
    </label>
    <label>
      <span>min rating</span>
      <select data-filter="rating">
        <option value="">any</option>
        {[10, 9, 8, 7, 6, 5].map((rating) => (
          <option value={rating}>{rating}+</option>
        ))}
      </select>
    </label>
    <div class="notes-count" data-count>{entries.length} notes</div>
  </section>

  <ul class="notes-list" data-list>
    {entries.map((entry) => (
      <li
        class="notes-item"
        data-title={entry.data.title.toLowerCase()}
        data-status={entry.data.status}
        data-year={entry.data.year ?? ''}
        data-rating={entry.data.rating ?? ''}
      >
        <a href={`/anime/${entry.id}`} class="notes-card">
          <div>
            <div class="notes-title">{entry.data.title}</div>
            <div class="notes-meta">
              <span>{entry.data.status}</span>
              {entry.data.year && <span>{entry.data.year}</span>}
              {entry.data.rating && <span>{entry.data.rating}/10</span>}
            </div>
          </div>
          <span class="notes-link">view</span>
        </a>
      </li>
    ))}
  </ul>

  {entries.length === 0 && <p class="notes-empty">No notes yet.</p>}
</Base>

<script is:inline>
  const filters = document.querySelectorAll('[data-filter]');
  const list = document.querySelector('[data-list]');
  const count = document.querySelector('[data-count]');

  if (list && count) {
    const applyFilters = () => {
      const search = document.querySelector('[data-filter="search"]').value.toLowerCase().trim();
      const status = document.querySelector('[data-filter="status"]').value;
      const year = document.querySelector('[data-filter="year"]').value;
      const rating = document.querySelector('[data-filter="rating"]').value;
      let visible = 0;

      list.querySelectorAll('.notes-item').forEach((item) => {
        const title = item.getAttribute('data-title') || '';
        const itemStatus = item.getAttribute('data-status') || '';
        const itemYear = item.getAttribute('data-year') || '';
        const itemRating = Number(item.getAttribute('data-rating') || 0);
        const minRating = rating ? Number(rating) : 0;

        const matchesSearch = !search || title.includes(search);
        const matchesStatus = !status || itemStatus === status;
        const matchesYear = !year || itemYear === year;
        const matchesRating = !minRating || itemRating >= minRating;

        const shouldShow = matchesSearch && matchesStatus && matchesYear && matchesRating;
        item.style.display = shouldShow ? '' : 'none';
        if (shouldShow) visible += 1;
      });

      count.textContent = `${visible} notes`;
    };

    filters.forEach((input) => {
      input.addEventListener('input', applyFilters);
      input.addEventListener('change', applyFilters);
    });
  }
</script>

<style>
  .notes-controls {
    display: grid;
    gap: var(--space-sm);
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    align-items: end;
    margin-bottom: var(--space-md);
    padding: var(--space-md);
    border: 1px solid var(--color-rule);
    border-radius: 12px;
    background: var(--color-surface);
  }

  .notes-controls label {
    display: grid;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: lowercase;
    color: var(--color-ink-faint);
  }

  .notes-controls input,
  .notes-controls select {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-ink);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-rule);
    border-radius: 8px;
    padding: 0.45rem 0.6rem;
  }

  .notes-count {
    justify-self: end;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-ink-faint);
  }

  .notes-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-sm);
  }

  .notes-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) 0;
    text-decoration: none;
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-rule);
  }

  .notes-item:last-child .notes-card {
    border-bottom: none;
  }

  .notes-title {
    font-size: var(--text-lg);
    font-weight: 600;
  }

  .notes-meta {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-ink-faint);
    text-transform: lowercase;
  }

  .notes-meta span + span::before {
    content: '·';
    margin-right: 0.6rem;
    color: var(--color-rule);
  }

  .notes-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-ink-faint);
    text-transform: lowercase;
  }

  .notes-empty {
    margin: 0;
    color: var(--color-ink-muted);
  }

  @media (max-width: 640px) {
    .notes-card {
      align-items: flex-start;
      flex-direction: column;
    }

    .notes-count {
      justify-self: start;
    }
  }
</style>
