---
export const prerender = true;
import Base from '../layouts/Base.astro';
import "../styles/games.css";
import { Minesweeper } from '../components/games/minesweeper/Minesweeper';
import { CommunityClicker } from '../components/games/CommunityClicker';
---

<Base title="games" description="A quiet corner for play.">
  <div class="games-container">
    <header class="page-header">
      <h1>Games</h1>
      <p class="subtitle">my little playground</p>
    </header>

    <article class="game-card">
      <div class="game-header">
        <div class="game-title">
          <h2>Minesweeper</h2>
          <span class="tag">Logic</span>
        </div>
      </div>
      
      <div class="game-body">
        <Minesweeper client:only="react" initialDifficulty="easy" />
      </div>
    </article>

    <article class="game-card game-card--compact">
      <div class="game-header">
        <div class="game-title">
          <h2>Clicker</h2>
          <span class="tag">Shared</span>
        </div>
      </div>

      <div class="game-body">
        <CommunityClicker client:only="react" />
      </div>
    </article>

    <!-- <footer class="page-footer">
      <span class="dot"></span>
      <span>More coming soon</span>
    </footer> -->
  </div>
</Base>
