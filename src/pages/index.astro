---
export const prerender = true;
import Base from '@layouts/Base.astro';
import { getPublishedPosts } from '@lib/content';

const posts = (await getPublishedPosts()).slice(0, 5);

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---
<Base title="oddava" description="A quiet corner of the internet.">
  <section class="intro">
    <img src="/images/resting-angel.jpg" class="intro-image" alt="oddava" />
    <p>
      Hi, I'm <a href="/about">oddava</a>. I'm curious about all sorts of things, especially AI and software engineering. It's really fascinating how these fields are evolving and how they intersect with each other. I'm trying to make sense of it all.
    </p>

    <br>

    <p>
      I don't expect this blog to be a source of truth or anything, but I hope it will be a place where I can share my thoughts and experiments with you.
    </p>
  </section>

  <hr />

  <section>
    <h2 class="section-heading">recent writing</h2>
    <ul class="post-list">
      {posts.map((post: any) => (
        <li class="post-item">
          <a href={`/blog/${post.id}`} class="post-item__link">
            <div class="post-item__title">{post.data.title}</div>
            <div class="post-item__meta">
              <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
            </div>
            {post.data.description && (
              <div class="post-item__description">{post.data.description}</div>
            )}
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>
