---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import { getAllProjects } from '../../lib/projects';

const projects = await getAllProjects();
---

<Base title="projects" description="Things I've built and experiments I've shipped.">
  <header class="projects-header">
    <h1>projects</h1>
    <p>things i've built, shipped, or am tinkering with.</p>
  </header>

  <ul class="project-grid">
    {projects.map((project) => (
      <li class="project-card">
        <div class="project-card__head">
          <h2 class="project-card__title">{project.title}</h2>
          {project.featured && <span class="project-card__badge">featured</span>}
        </div>

        <p class="project-card__desc">{project.description}</p>

        <div class="project-card__tech">
          {project.tech.map((t) => (
            <span class="tag-chip">{t}</span>
          ))}
        </div>

        <div class="project-card__links">
          {project.url && (
            <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-link">
              <span>live ↗</span>
            </a>
          )}
          {project.repo && (
            <a href={project.repo} target="_blank" rel="noopener noreferrer" class="project-link">
              <span>source ↗</span>
            </a>
          )}
        </div>
      </li>
    ))}
  </ul>

  {projects.length === 0 && (
    <p class="empty-state">Nothing here yet — check back soon.</p>
  )}
</Base>

<style>
  .projects-header {
    padding-top: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .projects-header p {
    margin-top: 0.4rem;
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
  }

  .project-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-md);
  }

  .project-card {
    padding: var(--space-sm) var(--space-sm) var(--space-sm);
    border: 1px solid var(--color-rule);
    border-radius: 10px;
    background: var(--color-surface);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .project-card:hover {
    border-color: var(--color-ink-faint);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }

  .project-card__head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.4rem;
  }

  .project-card__title {
    font-size: var(--text-lg);
    font-weight: 600;
    margin: 0;
    color: var(--color-ink);
  }

  .project-card__badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.1rem 0.4rem;
    border: 1px solid var(--color-accent);
    border-radius: 3px;
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
  }

  .project-card__desc {
    margin: 0 0 0.75rem 0;
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .project-card__tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }

  .project-card__links {
    display: flex;
    gap: 0.8rem;
  }

  .project-link {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: lowercase;
    color: var(--color-ink-faint);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .project-link:hover {
    color: var(--color-accent);
  }

  .empty-state {
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
    margin-top: var(--space-md);
  }
</style>
