---
export const prerender = true;
import Base from '../../layouts/Base.astro';

const allPosts = Object.values(
  import.meta.glob('../../content/blog/*.mdx', { eager: true })
) as any[];

const posts = allPosts
  .filter((post: any) => !post.frontmatter.draft)
  .sort((a: any, b: any) =>
    new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
  );

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}

function getPostSlug(filepath: string): string {
  const filename = filepath.split('/').pop() || '';
  return filename.replace('.mdx', '');
}
---
<Base title="writing" description="Things I've written.">
  <div class="about-content">
    <h1>writing</h1>
    <p>
      i dump my thoughts and ideas here
    </p>
  </div>

  <ul class="post-list" style="margin-top: var(--space-md);">
    {posts.map((post: any) => (
      <li class="post-item">
        <a href={`/blog/${getPostSlug(post.file)}`} class="post-item__link">
          <div class="post-item__title">{post.frontmatter.title}</div>
          <div class="post-item__meta">
            <time datetime={post.frontmatter.date}>{formatDate(post.frontmatter.date)}</time>
          </div>
          {post.frontmatter.description && (
            <div class="post-item__description">{post.frontmatter.description}</div>
          )}
        </a>
      </li>
    ))}
  </ul>
</Base>
